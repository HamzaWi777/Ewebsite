{
  "name": "ecommerce-store",
  "version": "1.0.0",
  "description": "Full-stack e-commerce clothing website",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm start -w server"
  },
  "keywords": [
    "ecommerce",
    "clothing",
    "store"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@fontsource/playfair-display": "^5.2.8"
  }
}
